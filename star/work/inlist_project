! inlist to evolve a 15 solar mass star

! For the sake of future readers of this file (yourself included),
! ONLY include the controls you are actually using.  DO NOT include
! all of the other controls that simply have their default values.

&star_job

   ! see star/defaults/star_job.defaults

   ! begin with a pre-main sequence model
   create_pre_main_sequence_model = .true.

   ! save a model at the end of the run
   save_model_when_terminate = .false.
   save_model_filename = '15M_at_TAMS.mod'

   ! display on-screen plots
   pgstar_flag = .true.

implicit_diffusion_flag = .false.
implicit_diffusion_include_dsig_dxa = .true.
implicit_diffusion_use_brunt_gauss_path = .false.
implicit_diffusion_include_dsig_structure = .true.

first_model_for_timing = 400
steps_before_start_timing = -1
/ ! end of star_job namelist


&eos

mass_fraction_limit_for_Skye = 1d-16

/ ! end of eos namelist


&kap

   ! kap options
   ! see kap/defaults/kap.defaults
   use_Type2_opacities = .true.
   Zbase = 0.02

/ ! end of kap namelist


&controls
max_model_number = 500

report_solver_progress = .true.
include_eos_composition_partials = .false.
use_ledoux_criterion = .true.
make_gradr_sticky_in_solver_iters = .true.


! essential to lower dq for implicit diffusion, need for convective boundaries
min_dq_for_xa_convective = 1d-12
min_dq_for_xa = 1d-12


    dX_limit_species(1) = 'h1'
    dX_limit_species(2) = 'he4'


      overshoot_scheme(1) = 'none'
      overshoot_zone_type(1) = 'any'
      overshoot_zone_loc(1) = 'any'
      overshoot_bdy_loc(1) = 'any'
      overshoot_f(1) = 0.005 ! for M>10
      !overshoot_f(1) = 0.21 ! For M<10 
      overshoot_f0(1) = 0.001


   ! see star/defaults/controls.defaults

   ! starting specifications
   initial_mass = 2.5 ! in Msun units
   initial_z = 0.02

   ! when to stop

   ! stop when the star nears ZAMS (Lnuc/L > 0.99)
   Lnuc_div_L_zams_limit = 0.99d0
   stop_near_zams = .false.

   ! stop when the center mass fraction of h1 drops below this limit
   !xa_central_lower_limit_species(1) = 'he4'
   !xa_central_lower_limit(1) = 1d-4

   ! wind

   ! atmosphere

   ! rotation

   ! element diffusion

   ! mlt

   ! mixing

   ! timesteps

   ! mesh

   ! solver
   ! options for energy conservation (see MESA V, Section 3)
   energy_eqn_option = 'dedt'
   use_gold_tolerances = .true.

   ! output

/ ! end of controls namelist
