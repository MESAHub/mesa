! star_job_dev
! ============

! .. warning::
!
!  CONTAINS OPTIONS THAT HAVE NOT YET BEEN THE GIVEN A GREEN LIGHT FOR GENERAL USE.
!  IN PARTICULAR, THESE ARE NOT YET FOR USE IN RESEARCH TO BE PUBLISHED.

      ! change_RSP2_flag
      ! ~~~~~~~~~~~~~~~~
      ! change_initial_RSP2_flag
      ! ~~~~~~~~~~~~~~~~~~~~~~~~
      ! change_RSP2_flag_at_model_number
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
      ! new_RSP2_flag
      ! ~~~~~~~~~~~~~
      ! create_RSP2_model
      ! ~~~~~~~~~~~~~~~~~

      ! WARNING: These controls are not ready for use.
      ! w is turbulent velocity according to RSP2

      ! ::

   change_RSP2_flag = .false.
   change_initial_RSP2_flag = .false.
   change_RSP2_flag_at_model_number = -111
   new_RSP2_flag = .false.
   create_RSP2_model = .false.


      ! remove_surface_by_relax_to_star_cut
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
      ! remove_surface_do_jrot
      ! ~~~~~~~~~~~~~~~~~~~~~~
      ! remove_surface_do_entropy
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~
      ! remove_surface_turn_off_energy_sources_and_sinks
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

      ! ::

   remove_surface_by_relax_to_star_cut = .false.
   remove_surface_do_jrot = .false.
   remove_surface_do_entropy = .true.
   remove_surface_turn_off_energy_sources_and_sinks = .true.


      ! change_w_div_wc_flag
      ! ~~~~~~~~~~~~~~~~~~~~
      ! change_initial_w_div_wc_flag
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~
      ! new_w_div_wc_flag
      ! ~~~~~~~~~~~~~~~~~

      ! w_div_wc variables
      ! ``w_div_wc_flag`` is true if we are using w_div_wc as a solver variable

      ! ::

   change_w_div_wc_flag = .false.
   change_initial_w_div_wc_flag = .false.
   new_w_div_wc_flag = .false.


      ! change_j_rot_flag
      ! ~~~~~~~~~~~~~~~~~
      ! change_initial_j_rot_flag
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~
      ! new_j_rot_flag
      ! ~~~~~~~~~~~~~~

      ! j_rot variables
      ! ``j-rot_flag`` is true if we are using j_rot as a solver variable

      ! ::

   change_j_rot_flag = .false.
   change_initial_j_rot_flag = .false.
   new_j_rot_flag = .false.


      ! use_w_div_wc_flag_with_rotation
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
      ! use_j_rot_flag_with_rotation
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~

      ! allows the use of rotation corrections and am transport to be computed with the
      ! general newton solver

      ! ::

   use_w_div_wc_flag_with_rotation = .false.
   use_j_rot_flag_with_rotation = .false.


      ! implicit_diffusion_flag
      ! ~~~~~~~~~~~~~~~~~~~~~~~

      ! if ``implicit_diffusion_flag`` is true, split ``D_mix`` into the
      ! autodiff ``Dmix_implicit`` bucket and the real ``Dmix_explicit``
      ! remainder. ``D_mix`` remains the final value used by existing callers.
      ! It is not compatible with ``use_other_brunt``,
      ! ``use_other_brunt_smoothing``, or ``use_other_mlt_results``.

      ! ::

   implicit_diffusion_flag = .false.


      ! implicit_diffusion_include_dsig_structure
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

      ! if ``implicit_diffusion_include_dsig_structure`` is true, include the
      ! structure-Jacobian terms from the dependence of the implicit diffusion
      ! coefficient on the current MLT/TDC state.  This is the main nonlinear
      ! implicit-Dmix coupling.  It can be turned off to diagnose convergence
      ! problems while leaving the fixed-coefficient composition solve implicit.
      ! It is off by default while the nonlinear coefficient coupling is being
      ! validated.

      ! ::

   implicit_diffusion_include_dsig_structure = .false.


      ! implicit_diffusion_include_dsig_dxa
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

      ! if ``implicit_diffusion_include_dsig_dxa`` is true, include the
      ! species-Jacobian terms from the composition dependence of the implicit
      ! diffusion coefficient, i.e. ``d_sig_dxa_m1`` and ``d_sig_dxa_00``.
      ! This term is only used when ``use_Ledoux_criterion`` is true.
      ! When enabled with ``implicit_diffusion_flag``, this also forces
      ! ``include_eos_composition_partials`` on for the hydro Jacobian.
      ! This is a high-gain convective-boundary coupling and is off by default
      ! while the implicit diffusion path is being validated.

      ! ::

   implicit_diffusion_include_dsig_dxa = .false.


      ! implicit_diffusion_use_brunt_finite_difference_value
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

      ! if ``implicit_diffusion_use_brunt_finite_difference_value`` is true,
      ! the implicit Brunt path uses the same finite two-composition EOS
      ! pressure difference as the ordinary Brunt path for the stored Brunt
      ! value.  The implicit derivatives still use the linearized face/path
      ! EOS pressure-composition partials.  If false, the stored value also
      ! uses the linearized EOS partial contraction.

      ! ::

   implicit_diffusion_use_brunt_finite_difference_value = .true.


      ! implicit_diffusion_use_brunt_gauss_path
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

      ! if ``implicit_diffusion_use_brunt_gauss_path`` is true, evaluate the
      ! implicit Brunt pressure-composition derivative coefficient by a
      ! two-point Gauss path average in composition. This costs two extra
      ! row-scoped face EOS calls per face and is off by default.

      ! ::

   implicit_diffusion_use_brunt_gauss_path = .false.


      ! load_saved_photo
      ! ~~~~~~~~~~~~~~~~
      ! saved_photo_name
      ! ~~~~~~~~~~~~~~~~

      ! ::

   load_saved_photo = .false.
   saved_photo_name = 'undefined'

      ! save_photo_number
      ! ~~~~~~~~~~~~~~~~~
      ! save_photo_filename
      ! ~~~~~~~~~~~~~~~~~~~
      ! save_photo_when_terminate
      ! ~~~~~~~~~~~~~~~~~~~~~~~~~

      ! ::

   save_photo_number = -1
   save_photo_filename = ''

!   ! save_photo_when_terminate = .true.


      ! create_merger_model
      ! ~~~~~~~~~~~~~~~~~~~
      ! saved_model_for_merger_1
      ! ~~~~~~~~~~~~~~~~~~~~~~~~
      ! saved_model_for_merger_2
      ! ~~~~~~~~~~~~~~~~~~~~~~~~

      ! !!! EXPERIMENTAL. !!!
      ! If ``create_merger_model`` is true, then create a star by merging the two models provided.

      ! ::

   create_merger_model = .false.
   saved_model_for_merger_1 = 'undefined'
   saved_model_for_merger_2 = 'undefined'
