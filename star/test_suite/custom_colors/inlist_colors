! Enhanced MESA inlist for stellar evolution with synthetic photometry
! This inlist evolves a star from pre-main sequence through multiple evolutionary phases
! Uses the custom colors module to calculate synthetic magnitudes in multiple filters

! Niall Miller (2026)

! =============================================================================
! STAR_JOB NAMELIST - Controls model creation and global job settings
! =============================================================================
&star_job
      ! Model creation settings
      create_pre_main_sequence_model = .true.  ! Start from pre-MS rather than ZAMS
      
      ! Termination conditions
      save_model_when_terminate = .true.
      save_model_filename = 'final.mod'
      
      ! Custom output files
      history_columns_file = 'custom_colors_history_columns.list'  ! Additional history columns
      
      ! Verbosity and debugging
      show_log_description_at_start = .true.  ! Print detailed info at start
      
      ! Pre-MS model settings
      pre_ms_relax_to_start_radiative_core = .false.  ! Colors will only show up after these steps. 
      initial_model_relax_num_steps = 10              ! These settings are not very scienticious.
      pre_ms_relax_num_steps = 10                     ! But this is a test for Colors module, not science.

      pgstar_flag     = .true.   !enable pg star for LC and HR
/

! =============================================================================
! EOS NAMELIST - Equation of state settings (using defaults)
! =============================================================================
&eos
/

! =============================================================================
! KAP NAMELIST - Opacity settings
! =============================================================================
&kap
      Zbase = 0.02d0               ! Base metallicity (Z) for opacity tables
      kap_file_prefix = 'gs98'     ! Use Grevesse & Sauval 1998 opacity tables
/



! =============================================================================
! COLORS NAMELIST - Synthetic photometry settings
! Custom colors and this project inlist by Niall Miller
! =============================================================================
&colors
      ! Enable the colors module
      use_colors = .true.
            
      ! Filter system specification
      ! This points to a directory containing Johnson filter transmission curves.
      ! The Johnson directory should contain files like:
      !   - U.dat, B.dat, V.dat, R.dat, I.dat, J.dat, M.dat   (filter transmission curves)
      instrument = 'data/colors_data/filters/Generic/Johnson'

      ! Stellar atmosphere model directory
      ! Should contain:
      ! - lookup_table.csv: mapping file with columns for filename, Teff, log_g, metallicity
      ! - Individual SED files: wavelength vs surface flux for each stellar model
      ! - flux_cube.bin: pre-computed interpolation grid (if using linear/hermite interpolation)
      stellar_atm = 'data/colors_data/stellar_models/Kurucz2003all/'
      
      ! Physical parameters for synthetic photometry
      distance = 3.0857d19         ! Distance to star in cm (1 pc = 3.0857e16 m for absolute mags)
      
      ! Output options
      colors_results_directory = 'SED'
      make_csv = .true.            ! Write detailed SED files showing filter convolution  -- This is also needed for plotting the SED.
                                   ! Creates files like: SED/B_SED.csv, SED/VEGA_B_SED.csv

      !zero point. Select between: Vega, AB, ST
      mag_system = 'Vega'

      ! Vega spectrum for zero-point calibration
      ! This file should contain wavelength (Å) and flux (erg/s/cm²/Å) columns
      ! Used to define the zero-point of the magnitude system (Vega = 0.0 mag)
      vega_sed = 'data/colors_data/stellar_models/vega_flam.csv'


/ ! end of colors namelist




! =============================================================================
! CONTROLS NAMELIST - Main stellar evolution parameters
! =============================================================================
&controls
      ! --- BASIC STELLAR PARAMETERS ---
      ! 7.0 Solar Masses creates a very distinct "Blue Loop" during He-burning
      ! This causes the star to swing from Red -> Blue -> Red rapidly.
      initial_mass = 7.0d0            
      
      ! Solar metallicity makes for redder Red Giants and clearer loops
      initial_z = 0.02d0              

      ! --- STOPPING CONDITIONS ---
      xa_central_lower_limit_species(1) = 'he4'
      xa_central_lower_limit(1) = 1d-2  

      ! Fail-safe max age (just in case)
      max_age = 1d12               

      ! --- OUTPUT CONTROL ---
      ! High resolution history for smooth light curves
      history_interval = 1         
      profile_interval = 50        
      
      ! --- NUMERICAL CONTROLS ---
      varcontrol_target = 1d-3
      mesh_delta_coeff = 0.5   


/



&pgstar
  ! Live pgstar dashboard for the synthetic photometry / colors-module run.
  ! Designed for the uploaded blue-loop inlist_run using GAIA colors:
  !   G, Gbp, Grp, LOGS/SED, HR, Kipp, and History_Track panels.

  file_white_on_black_flag = .false.
  pgstar_interval = 1

  ! Keep the standard component windows off; render HR/Kipp inside Grid8.
  HR_win_flag = .false.
  Kipp_win_flag = .false.

  ! ---------------------------------------------------------------------------
  ! Individual panel definitions
  ! ---------------------------------------------------------------------------

  ! Physics context: where the star is moving in Teff-L space.
  HR_title = 'HR diagram'
  HR_logL_margin = 0.1
  HR_logT_margin = 0.1
  HR_dlogT_min = -1
  HR_dlogL_min = -1

  ! Colors module output: Johnson CMD.
  Color_Magnitude1_num_panels = 1
  Color_Magnitude1_xaxis1_name = 'B - R'
  Color_Magnitude1_yaxis1_name = 'V'
  Color_Magnitude1_xaxis_reversed = .false.
  Color_Magnitude1_yaxis_reversed = .true.
  Color_Magnitude1_title = 'Johnson CMD: V vs B-R'
  Color_Magnitude1_txt_scale = 0.75

  ! Colors module output: Johnson color-color plane.
  Color_Magnitude2_num_panels = 1
  Color_Magnitude2_xaxis1_name = 'B - V'
  Color_Magnitude2_yaxis1_name = 'V - R'
  Color_Magnitude2_xaxis_reversed = .false.
  Color_Magnitude2_yaxis_reversed = .false.
  Color_Magnitude2_title = 'Johnson colour-colour'
  Color_Magnitude2_txt_scale = 0.75

  ! Colors module output: live synthetic SED and filter response overlay.
  SED1_title = 'Live synthetic SED + filters'
  SED1_txt_scale = 0.75
  SED1_lambda_min = 100.0
  SED1_lambda_max = 10000.0
  SED1_flux_min = -15.0d0
  SED1_flux_max = 0.0d0
  SED1_filter_scale = 1.0

  ! Complementary physics: interior structure during the blue loop.
  Kipp_title = 'Interior structure'
  Kipp_mass_min = 0
  Kipp_show_mass_boundaries = .true.
  Kipp_show_mixing = .true.
  Kipp_max_width = -1

  ! Colors module output as a time series.
  History_Track1_title = 'Johnson V magnitude'
  History_Track1_xname = 'star_age'
  History_Track1_yname = 'V'
  History_Track1_xaxis_label = 'Age (yr)'
  History_Track1_yaxis_label = 'M_V'
  History_Track1_reverse_xaxis = .false.

  ! ---------------------------------------------------------------------------
  ! Grid8 dashboard layout: 3 columns x 2 rows
  ! ---------------------------------------------------------------------------
  Grid8_win_flag = .true.
  Grid8_win_width = 18
  Grid8_win_aspect_ratio = 0.62

  Grid8_file_flag = .true.
  Grid8_file_dir = 'plots'
  Grid8_file_prefix = 'colors_dashboard_'
  Grid8_file_interval = 5
  Grid8_file_width = 18
  Grid8_file_aspect_ratio = 0.62

  Grid8_num_cols = 3
  Grid8_num_rows = 2
  Grid8_num_plots = 6

  ! Top left: the direct colors-module product.
  Grid8_plot_name(1) = 'sed1'
  Grid8_plot_row(1) = 1
  Grid8_plot_col(1) = 1
  Grid8_plot_rowspan(1) = 1
  Grid8_plot_colspan(1) = 1
  Grid8_plot_pad_left(1) = 0.06
  Grid8_plot_pad_right(1) = 0.03
  Grid8_plot_pad_top(1) = 0.05
  Grid8_plot_pad_bot(1) = 0.08
  Grid8_txt_scale_factor(1) = 0.75

  ! Top centre: observational CMD track.
  Grid8_plot_name(2) = 'Color_Magnitude1'
  Grid8_plot_row(2) = 1
  Grid8_plot_col(2) = 2
  Grid8_plot_rowspan(2) = 1
  Grid8_plot_colspan(2) = 1
  Grid8_plot_pad_left(2) = 0.06
  Grid8_plot_pad_right(2) = 0.03
  Grid8_plot_pad_top(2) = 0.05
  Grid8_plot_pad_bot(2) = 0.08
  Grid8_txt_scale_factor(2) = 0.75

  ! Top right: observational color-color track.
  Grid8_plot_name(3) = 'Color_Magnitude2'
  Grid8_plot_row(3) = 1
  Grid8_plot_col(3) = 3
  Grid8_plot_rowspan(3) = 1
  Grid8_plot_colspan(3) = 1
  Grid8_plot_pad_left(3) = 0.06
  Grid8_plot_pad_right(3) = 0.03
  Grid8_plot_pad_top(3) = 0.05
  Grid8_plot_pad_bot(3) = 0.08
  Grid8_txt_scale_factor(3) = 0.75

  ! Bottom left: physical evolution corresponding to the photometry.
  Grid8_plot_name(4) = 'HR'
  Grid8_plot_row(4) = 2
  Grid8_plot_col(4) = 1
  Grid8_plot_rowspan(4) = 1
  Grid8_plot_colspan(4) = 1
  Grid8_plot_pad_left(4) = 0.06
  Grid8_plot_pad_right(4) = 0.03
  Grid8_plot_pad_top(4) = 0.05
  Grid8_plot_pad_bot(4) = 0.08
  Grid8_txt_scale_factor(4) = 0.75

  ! Bottom centre: stellar structure / mixing context.
  Grid8_plot_name(5) = 'Kipp'
  Grid8_plot_row(5) = 2
  Grid8_plot_col(5) = 2
  Grid8_plot_rowspan(5) = 1
  Grid8_plot_colspan(5) = 1
  Grid8_plot_pad_left(5) = 0.06
  Grid8_plot_pad_right(5) = 0.03
  Grid8_plot_pad_top(5) = 0.05
  Grid8_plot_pad_bot(5) = 0.08
  Grid8_txt_scale_factor(5) = 0.75

  ! Bottom right: one-band synthetic magnitude through time.
  Grid8_plot_name(6) = 'History_Track1'
  Grid8_plot_row(6) = 2
  Grid8_plot_col(6) = 3
  Grid8_plot_rowspan(6) = 1
  Grid8_plot_colspan(6) = 1
  Grid8_plot_pad_left(6) = 0.06
  Grid8_plot_pad_right(6) = 0.03
  Grid8_plot_pad_top(6) = 0.05
  Grid8_plot_pad_bot(6) = 0.08
  Grid8_txt_scale_factor(6) = 0.75

/ ! end of pgstar namelist
