	date-modified = {2020-12-09 01:08:04 -0700},
	doi = {10.1007/s10509-010-0269-2},
	journal = {\apss},
	keywords = {Equation of state, Plasmas, Atomic processes, Stars: evolution, Sun: helioseismology},
	month = jul,
	pages = {139-146},
